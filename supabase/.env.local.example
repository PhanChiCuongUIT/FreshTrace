# FreshTrace local Edge Function secrets
# Copy this file to supabase/.env.local.
# SUPABASE_* variables are supplied automatically by the Edge Runtime.

APP_ENV=local
APP_URL=http://localhost:5173
API_BASE_URL=http://localhost:54321/functions/v1
ALLOWED_ORIGINS=http://localhost:5173

CLOUDINARY_CLOUD_NAME=your_cloudinary_cloud_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret
CLOUDINARY_UPLOAD_PRESET=freshtrace_unsigned

PAYOS_CLIENT_ID=your_payos_client_id
PAYOS_API_KEY=your_payos_api_key
PAYOS_CHECKSUM_KEY=your_payos_checksum_key
PAYOS_RETURN_URL=http://localhost:5173/payment/success
PAYOS_CANCEL_URL=http://localhost:5173/payment/cancel
PAYOS_WEBHOOK_URL=http://localhost:54321/functions/v1/payos-webhook

USE_AI_ASSISTANT=false
AI_PROVIDER=rule-based
GEMINI_API_KEY=your_gemini_api_key
OPENAI_API_KEY=your_openai_api_key

QR_TRACE_BASE_URL=http://localhost:5173/trace
EDGE_FUNCTION_SECRET=replace_with_at_least_32_random_characters
WEBHOOK_VERIFY_SECRET=replace_with_at_least_32_random_characters
