# FreshTrace frontend production environment variables

VITE_APP_NAME=FreshTrace
VITE_APP_ENV=production
VITE_APP_URL=https://your-domain.com
VITE_API_BASE_URL=https://your-project-ref.supabase.co/functions/v1

VITE_AUTH_REDIRECT_URL=https://your-domain.com/auth/callback
VITE_PASSWORD_RESET_REDIRECT_URL=https://your-domain.com/reset-password

VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your_supabase_publishable_key

VITE_CLOUDINARY_CLOUD_NAME=your_cloudinary_cloud_name
VITE_CLOUDINARY_UPLOAD_PRESET=freshtrace_unsigned
VITE_CLOUDINARY_FOLDER_PRODUCTS=freshtrace/products
VITE_CLOUDINARY_FOLDER_CERTIFICATES=freshtrace/certificates
VITE_CLOUDINARY_FOLDER_DELIVERIES=freshtrace/deliveries
VITE_CLOUDINARY_FOLDER_AVATARS=freshtrace/avatars

VITE_PAYOS_RETURN_URL=https://your-domain.com/payment/success
VITE_PAYOS_CANCEL_URL=https://your-domain.com/payment/cancel

VITE_QR_TRACE_BASE_URL=https://your-domain.com/trace
VITE_QR_BATCH_PREFIX=FRESHTRACE-BATCH

VITE_FUNCTION_CREATE_PAYOS_PAYMENT=create-payos-payment
VITE_FUNCTION_PAYOS_WEBHOOK=payos-webhook
VITE_FUNCTION_GENERATE_BATCH_QR=generate-batch-qr
VITE_FUNCTION_FRESH_ASSISTANT=fresh-assistant
VITE_FUNCTION_SIGN_CLOUDINARY_UPLOAD=sign-cloudinary-upload
VITE_FUNCTION_CREATE_NOTIFICATION=create-notification
VITE_FUNCTION_TRACE_BATCH=trace-batch
VITE_FUNCTION_ASSIGN_DELIVERY=assign-delivery
VITE_FUNCTION_VERIFY_DELIVERY_BATCH=verify-delivery-batch
VITE_FUNCTION_UPDATE_DELIVERY_STATUS=update-delivery-status
VITE_FUNCTION_ADMIN_USERS=admin-users
VITE_FUNCTION_CANCEL_ORDER=cancel-order

VITE_ENABLE_PAYOS=true
VITE_ENABLE_CLOUDINARY=true
VITE_ENABLE_QR_TRACE=true
VITE_ENABLE_FRESH_RESCUE=true
VITE_ENABLE_REALTIME_CHAT=true
VITE_ENABLE_NOTIFICATIONS=true
VITE_ENABLE_FRESH_ASSISTANT=true

VITE_DEFAULT_PAGE_SIZE=12
VITE_ENABLE_DEV_LOG=false
