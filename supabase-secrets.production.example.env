# FreshTrace Supabase Cloud Edge Function secrets
# Copy to supabase-secrets.production.env and fill real values.
# Never commit supabase-secrets.production.env.

APP_ENV=production
APP_URL=https://freshtrace-app.vercel.app
ALLOWED_ORIGINS=https://freshtrace-app.vercel.app,https://freshtrace.online,https://www.freshtrace.online

# Resend SMTP for governance emails sent by Edge Functions.
# Supabase Auth SMTP is configured separately in Supabase Dashboard.
SMTP_HOST=smtp.resend.com
SMTP_PORT=465
SMTP_USER=resend
SMTP_PASS=re_your_resend_api_key
SMTP_ADMIN_EMAIL=no-reply@mail.freshtrace.online
SMTP_SENDER_NAME=FreshTrace
SUPPORT_EMAIL=support@freshtrace.online

CLOUDINARY_CLOUD_NAME=your_cloudinary_cloud_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret

PAYOS_CLIENT_ID=your_payos_client_id
PAYOS_API_KEY=your_payos_api_key
PAYOS_CHECKSUM_KEY=your_payos_checksum_key
PAYOS_RETURN_URL=https://freshtrace-app.vercel.app/payment/success
PAYOS_CANCEL_URL=https://freshtrace-app.vercel.app/payment/cancel
PAYOS_WEBHOOK_URL=https://puwfoxlvjzudypbxtrnr.supabase.co/functions/v1/payos-webhook

USE_AI_ASSISTANT=true
AI_PROVIDER=gemini
GEMINI_API_KEY=your_gemini_api_key
GEMINI_MODEL=gemini-1.5-flash

QR_TRACE_BASE_URL=https://freshtrace-app.vercel.app/trace
QR_BATCH_PREFIX=FRESHTRACE-BATCH

EDGE_FUNCTION_SECRET=replace_with_at_least_32_random_characters
WEBHOOK_VERIFY_SECRET=replace_with_at_least_32_random_characters
